# ─────────────────────────────────────────────────────────────
# Variables de entorno — NexoTT Learn
# Copiar como `.env` para desarrollo local.
# Para staging/produccion ver docs/DEPLOYMENT.md (Railway).
# ─────────────────────────────────────────────────────────────

# Postgres (docker-compose local)
POSTGRES_USER=nexott
POSTGRES_PASSWORD=nexott_dev
POSTGRES_DB=nexott_learn
POSTGRES_PORT=5435

# API (NestJS)
API_PORT=4000
NODE_ENV=development
DATABASE_URL=postgresql://nexott:nexott_dev@localhost:5435/nexott_learn?schema=public
SESSION_SECRET=cambiar_en_produccion_minimo_32_caracteres_random
# Origen del frontend permitido por CORS. En prod va la URL real (ej. https://learn.nexott.tld)
# Acepta multiples separados por coma (util para previews de PRs).
WEB_ORIGIN=http://localhost:5173

# Web (Vite SPA)
# URL absoluta de la API. En dev se ignora (vite proxy redirige /api).
# En build de prod, vite la inlinea al bundle.
VITE_API_URL=http://localhost:4000

# GitHub Packages (para instalar @carlos2280/nexott-ui en CI/Railway)
# En local NO es necesaria si tienes .pnpmfile.cjs apuntando a ../nexott-ui.
# NODE_AUTH_TOKEN=ghp_xxxxxxxxxxxx
