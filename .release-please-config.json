{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "include-component-in-tag": false,
  "include-v-in-tag": true,
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "draft": false,
  "prerelease": false,
  "changelog-sections": [
    { "type": "feat", "section": "Funcionalidades", "hidden": false },
    { "type": "fix", "section": "Correcciones", "hidden": false },
    { "type": "perf", "section": "Rendimiento", "hidden": false },
    { "type": "refactor", "section": "Refactor", "hidden": false },
    { "type": "docs", "section": "Documentacion", "hidden": false },
    { "type": "build", "section": "Build", "hidden": true },
    { "type": "ci", "section": "CI/CD", "hidden": true },
    { "type": "chore", "section": "Mantenimiento", "hidden": true },
    { "type": "style", "section": "Estilo", "hidden": true },
    { "type": "test", "section": "Tests", "hidden": true },
    { "type": "revert", "section": "Reverts", "hidden": false }
  ],
  "packages": {
    ".": {
      "package-name": "nexott-learn",
      "changelog-path": "CHANGELOG.md"
    }
  }
}
