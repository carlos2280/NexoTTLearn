{
  "name": "@nexott-learn/shared-types",
  "version": "0.1.0",
  "private": true,
  "sideEffects": false,
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/cjs/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.build.esm.json",
    "typecheck": "tsc --noEmit",
    "lint": "cd ../.. && biome check packages/shared-types/src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "3.24.1"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  }
}
