{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm --filter @nexott-learn/api:*)",
      "Bash(pnpm --filter @nexott-learn/web:*)",
      "Bash(pnpm dev:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm db:migrate:*)",
      "Bash(pnpm db:seed:*)",
      "Bash(pnpm db:studio:*)",
      "Bash(make dev:*)",
      "Bash(make dev-web:*)",
      "Bash(make dev-api:*)",
      "Bash(make typecheck)",
      "Bash(make lint)",
      "Bash(make test)",
      "Bash(make validate)",
      "Bash(make build)",
      "Bash(make db-up)",
      "Bash(make db-down)",
      "Bash(make db-migrate)",
      "Bash(make db-seed)",
      "Bash(make db-studio)",
      "Bash(make kill)",
      "Bash(make ps)",
      "Bash(make ports)",
      "Bash(make status)",
      "Bash(make vite-cache-clear)"
    ],
    "ask": [
      "Bash(make db-reset)",
      "Bash(make fresh)",
      "Bash(pnpm prisma migrate deploy:*)",
      "Bash(pnpm prisma db push:*)",
      "Bash(pnpm publish:*)",
      "Edit(./biome.json)",
      "Write(./biome.json)",
      "Edit(./.husky/**)",
      "Write(./.husky/**)",
      "Edit(./commitlint.config.js)",
      "Edit(./turbo.json)",
      "Edit(./.github/workflows/**)",
      "Edit(./Makefile)",
      "Edit(./tsconfig*.json)",
      "Edit(./apps/*/tsconfig*.json)"
    ],
    "deny": [
      "Bash(rm -rf apps:*)",
      "Bash(rm -rf packages:*)",
      "Bash(rm -rf prisma:*)",
      "Bash(git commit --no-verify:*)",
      "Bash(git push --no-verify:*)",
      "Bash(git commit -n:*)",
      "Bash(git push -n:*)",
      "Bash(HUSKY=0:*)",
      "Bash(SKIP_HOOKS=:*)",
      "Bash(biome check --fix:*)",
      "Bash(biome --apply:*)",
      "Bash(pnpm biome check --fix:*)",
      "Bash(pnpm exec biome check --fix:*)",
      "Read(./apps/api/.env)",
      "Read(./apps/web/.env)",
      "Read(./.env)",
      "Read(./.env.tokens)"
    ]
  },
  "includeCoAuthoredBy": false
}
