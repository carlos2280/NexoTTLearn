    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@carlos2280/nexott-ui": "^0.6.0",
    "@hookform/resolvers": "3.9.1",
    "@lit/react": "^1.0.8",
    "@nexott-learn/shared-types": "workspace:*",
    "@tanstack/react-query": "5.64.2",
    "@tanstack/table-core": "^8.0.0",
    "compression": "1.7.5",
    "express": "4.21.2",
    "helmet": "8.0.0",
    "lit": "^3.0.0",
    "qrcode": "^1.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "7.54.2",
    "react-router-dom": "6.28.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "4.3.4",
    "typescript": "5.7.3",
    "vite": "5.4.11",
    "vitest": "2.1.8"
  }
