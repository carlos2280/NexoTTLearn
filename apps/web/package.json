{
  "name": "@nexott-learn/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "node server.js",
    "typecheck": "tsc --noEmit",
    "lint": "cd ../.. && biome check apps/web/src/ apps/web/server.js",
