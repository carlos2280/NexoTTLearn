{
  "name": "@nexott-learn/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build && tsc-alias -p tsconfig.build.json",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "cd ../.. && biome check apps/api/src/ apps/api/test/ apps/api/prisma/seed.ts apps/api/prisma/seeds/",
    "lint:fix": "cd ../.. && biome check --write apps/api/src/ apps/api/test/ apps/api/prisma/seed.ts apps/api/prisma/seeds/",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@nestjs/common": "10.4.15",
    "@nestjs/config": "3.3.0",
    "@nestjs/core": "10.4.15",
    "@nestjs/platform-express": "10.4.15",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6.5.0",
    "@nexott-learn/shared-types": "workspace:*",
    "@prisma/client": "6.1.0",
    "bcrypt": "5.1.1",
    "connect-pg-simple": "10.0.0",
    "cookie-parser": "1.4.7",
    "exceljs": "^4.4.0",
    "express-session": "1.18.1",
    "gray-matter": "^4.0.3",
    "helmet": "8.0.0",
    "markdown-it": "^14.2.0",
    "multer": "^2.1.1",
    "nestjs-pino": "^4.6.1",
    "otplib": "^13.4.0",
    "pdfkit": "^0.15.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "0.2.2",
    "resend": "^6.12.3",
    "rxjs": "7.8.1",
    "yaml": "^2.9.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.9",
    "@nestjs/schematics": "10.2.3",
    "@nestjs/testing": "10.4.15",
    "@types/bcrypt": "5.0.2",
    "@types/connect-pg-simple": "7.0.3",
    "@types/cookie-parser": "1.4.8",
    "@types/express": "5.0.0",
    "@types/express-session": "1.18.1",
    "@types/markdown-it": "^14.1.2",
    "@types/multer": "^2.1.0",
    "@types/node": "22.10.5",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "6.0.2",
    "pino-pretty": "^13.1.3",
    "prisma": "6.1.0",
    "supertest": "7.0.0",
    "tsc-alias": "1.8.10",
    "tsconfig-paths": "4.2.0",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
