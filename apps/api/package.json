{
  "name": "@nexott-learn/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build && tsc-alias -p tsconfig.build.json",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "cd ../.. && biome check apps/api/src/ apps/api/test/ apps/api/prisma/seed.ts",
    "lint:fix": "cd ../.. && biome check --write apps/api/src/ apps/api/test/ apps/api/prisma/seed.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:reset": "tsx prisma/seed.ts --reset",
    "db:seed:minimal": "tsx prisma/seed.ts --minimal",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@nestjs/common": "10.4.15",
    "@nestjs/config": "3.3.0",
    "@nestjs/core": "10.4.15",
    "@nestjs/passport": "10.0.3",
    "@nestjs/platform-express": "10.4.15",
    "@nestjs/throttler": "^6.5.0",
    "@nexott-learn/shared-types": "workspace:*",
    "@prisma/client": "6.1.0",
    "bcrypt": "5.1.1",
    "connect-pg-simple": "10.0.0",
    "cookie-parser": "1.4.7",
    "exceljs": "^4.4.0",
    "express-session": "1.18.1",
    "helmet": "8.0.0",
    "multer": "^2.1.1",
    "otplib": "^13.4.0",
    "passport": "0.7.0",
    "qrcode": "^1.5.4",
    "passport-local": "1.0.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.9",
    "@nestjs/schematics": "10.2.3",
    "@nestjs/testing": "10.4.15",
    "@types/bcrypt": "5.0.2",
    "@types/connect-pg-simple": "7.0.3",
    "@types/cookie-parser": "1.4.8",
    "@types/express": "5.0.0",
    "@types/express-session": "1.18.1",
    "@types/multer": "^2.1.0",
    "@types/node": "22.10.5",
    "@types/passport": "1.0.17",
    "@types/passport-local": "1.0.38",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "6.0.2",
    "prisma": "6.1.0",
    "supertest": "7.0.0",
    "tsc-alias": "1.8.10",
    "tsconfig-paths": "4.2.0",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
