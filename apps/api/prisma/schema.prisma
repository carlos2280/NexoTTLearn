enum ArchivoTipo {
  EVALUACION_INICIAL_EXCEL

  @@map("archivo_tipo_enum")
}

// =============================================================================
// CATALOGO: areas, skills, modulos, secciones, bloques
// =============================================================================

model Area {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre      String   @unique
  descripcion String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  skills                        Skill[]
  cursosAreasExigidas           CursoAreaExigida[]
  rubricaEntrevistaIA           RubricaEntrevistaIA[]
  intentosEntrevistaIANotasArea IntentoEntrevistaIANotaArea[]
  historicoCambiosAreaAnterior  HistoricoCambiosAreaSkill[]   @relation("HistCambiosArea_Anterior")
  historicoCambiosAreaNueva     HistoricoCambiosAreaSkill[]   @relation("HistCambiosArea_Nueva")

  @@map("areas")
}

model Skill {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  etiquetaVisible String      @unique @map("etiqueta_visible")
  areaId          String      @map("area_id") @db.Uuid
  estado          EstadoSkill @default(ACTIVA)
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  area                 Area                        @relation(fields: [areaId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  historicoRenombrados HistoricoRenombradoSkill[]
  historicoCambiosArea HistoricoCambiosAreaSkill[]
  seccionesSkills      SeccionSkill[]
  bloquesEvaluan       Bloque[]
  cursosSkillsExigidas CursoSkillExigida[]
  transversalesSkills  TransversalSkill[]
  notasSkill           NotaSkill[]
  intentosBloque       IntentoBloque[]

  @@index([areaId], map: "idx_skills_area_id")
  @@map("skills")
}

model HistoricoRenombradoSkill {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  skillId          String   @map("skill_id") @db.Uuid
  fecha            DateTime @default(now()) @db.Timestamptz(6)
  etiquetaAnterior String   @map("etiqueta_anterior")
  etiquetaNueva    String   @map("etiqueta_nueva")
  autorUsuarioId   String   @map("autor_usuario_id") @db.Uuid
  motivo           String?

  skill        Skill   @relation(fields: [skillId], references: [id], onDelete: Restrict)
  autorUsuario Usuario @relation("HistRenombradoSkill_Autor", fields: [autorUsuarioId], references: [id], onDelete: Restrict)

  @@index([skillId, fecha(sort: Desc)], map: "idx_historico_renombrados_skill_id")
  @@map("historico_renombrados_skill")
}

model HistoricoCambiosAreaSkill {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  skillId        String   @map("skill_id") @db.Uuid
  fecha          DateTime @default(now()) @db.Timestamptz(6)
  areaAnteriorId String   @map("area_anterior_id") @db.Uuid
  areaNuevaId    String   @map("area_nueva_id") @db.Uuid
  autorUsuarioId String   @map("autor_usuario_id") @db.Uuid
  motivo         String

  skill        Skill   @relation(fields: [skillId], references: [id], onDelete: Restrict)
  areaAnterior Area    @relation("HistCambiosArea_Anterior", fields: [areaAnteriorId], references: [id], onDelete: Restrict)
  areaNueva    Area    @relation("HistCambiosArea_Nueva", fields: [areaNuevaId], references: [id], onDelete: Restrict)
  autorUsuario Usuario @relation("HistCambiosAreaSkill_Autor", fields: [autorUsuarioId], references: [id], onDelete: Restrict)

  @@index([skillId, fecha(sort: Desc)])
  @@map("historico_cambios_area_skill")
}

model Modulo {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titulo      String
  descripcion String?
  estado      EstadoModulo @default(ACTIVO)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?    @map("deleted_at") @db.Timestamptz(6)

  secciones                Seccion[]
  historicoEstados         HistoricoEstadoModulo[]
  cursosModulosHabilitados CursoModuloHabilitado[]
  itemsPlan                ItemPlan[]

  @@map("modulos")
}

model HistoricoEstadoModulo {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  moduloId       String       @map("modulo_id") @db.Uuid
  fecha          DateTime     @default(now()) @db.Timestamptz(6)
  estadoAnterior EstadoModulo @map("estado_anterior")
  estadoNuevo    EstadoModulo @map("estado_nuevo")
  autorUsuarioId String       @map("autor_usuario_id") @db.Uuid
  motivo         String

  modulo       Modulo  @relation(fields: [moduloId], references: [id], onDelete: Restrict)
  autorUsuario Usuario @relation("HistEstadoModulo_Autor", fields: [autorUsuarioId], references: [id], onDelete: Restrict)

  @@index([moduloId, fecha(sort: Desc)])
  @@map("historico_estados_modulo")
}

model Seccion {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  moduloId  String   @map("modulo_id") @db.Uuid
  titulo    String
  orden     Int
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  modulo                            Modulo                           @relation(fields: [moduloId], references: [id], onDelete: Restrict)
  skills                            SeccionSkill[]
  bloques                           Bloque[]
  itemsPlan                         ItemPlan[]
  ajustesPlan                       AjustePlan[]
  intentosEntrevistaIASeccionesBase IntentoEntrevistaIASeccionBase[]
  aperturas                         AperturaSeccion[]

  @@unique([moduloId, orden], map: "uq_secciones_modulo_orden")
  @@index([moduloId, orden], map: "idx_secciones_modulo")
  @@map("secciones")
}

model SeccionSkill {
  seccionId String @map("seccion_id") @db.Uuid
  skillId   String @map("skill_id") @db.Uuid

  seccion Seccion @relation(fields: [seccionId], references: [id], onDelete: Cascade)
  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Restrict)

  @@id([seccionId, skillId])
  @@index([skillId], map: "idx_secciones_skills_skill")
  @@map("secciones_skills")
}

model Bloque {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seccionId      String       @map("seccion_id") @db.Uuid
  orden          Int
  tipo           TipoBloque
  esEvaluable    Boolean      @map("es_evaluable")
  skillQueMideId String?      @map("skill_que_mide_id") @db.Uuid
  contenido      Json         @default("{}") @db.JsonB
  estado         EstadoBloque @default(ACTIVO)
  version        Int          @default(1)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  seccion      Seccion         @relation(fields: [seccionId], references: [id], onDelete: Restrict)
  skillQueMide Skill?          @relation(fields: [skillQueMideId], references: [id], onDelete: Restrict)
  intentos     IntentoBloque[]

  @@unique([seccionId, orden], map: "uq_bloques_seccion_orden")
  @@index([seccionId, orden], map: "idx_bloques_seccion")
  @@map("bloques")
}

// =============================================================================
// CLIENTES Y CURSOS
// =============================================================================

model Cliente {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre        String    @unique
  datosContacto Json?     @map("datos_contacto") @db.JsonB
  activo        Boolean   @default(true)
  fechaCreacion DateTime  @default(now()) @map("fecha_creacion") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)

  cursos Curso[]

  @@map("clientes")
}

model Curso {
  id                     String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titulo                 String
  clienteId              String          @map("cliente_id") @db.Uuid
  estado                 EstadoCurso     @default(BORRADOR)
  fechaInicio            DateTime        @map("fecha_inicio") @db.Date
  fechaDeadline          DateTime        @map("fecha_deadline") @db.Date
  toggleVoluntarios      Boolean         @default(true) @map("toggle_voluntarios")
  toggleCierreAutomatico Boolean         @default(false) @map("toggle_cierre_automatico")
  umbralNoCumple         Decimal         @default(10.00) @map("umbral_no_cumple") @db.Decimal(5, 2)
  pesoBloques            Decimal         @default(70.00) @map("peso_bloques") @db.Decimal(5, 2)
  pesoTransversal        Decimal         @default(20.00) @map("peso_transversal") @db.Decimal(5, 2)
  pesoEntrevista         Decimal         @default(10.00) @map("peso_entrevista") @db.Decimal(5, 2)
  transversalId          String?         @unique @map("transversal_id") @db.Uuid
  entrevistaIaId         String?         @unique @map("entrevista_ia_id") @db.Uuid
  umbralesLogro          Json?           @map("umbrales_logro") @db.JsonB
  desbloqueo             DesbloqueoCurso @default(ENCADENADO)
  fechaDesbloqueo        DateTime?       @map("fecha_desbloqueo") @db.Date
  fechaCierre            DateTime?       @map("fecha_cierre") @db.Timestamptz(6)
  createdAt              DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  cliente            Cliente                 @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  transversal        ProyectoTransversal?    @relation(fields: [transversalId], references: [id], onDelete: SetNull)
  entrevistaIA       EntrevistaIA?           @relation(fields: [entrevistaIaId], references: [id], onDelete: SetNull)
  areasExigidas      CursoAreaExigida[]
  skillsExigidas     CursoSkillExigida[]
  modulosHabilitados CursoModuloHabilitado[]
  logCambios         LogCambioCurso[]
  asignaciones       AsignacionCurso[]
  intentosBloque     IntentoBloque[]
  previewsEvalInicial PreviewEvaluacionInicial[] @relation("PreviewEvalInicial_Curso")
  cargasEvalInicial   CargaEvaluacionInicial[]   @relation("CargaEvalInicial_Curso")

  @@index([clienteId], map: "idx_cursos_cliente")
  @@index([estado], map: "idx_cursos_estado")
  @@index([fechaDeadline], map: "idx_cursos_deadline")
  @@map("cursos")
}

model CursoAreaExigida {
  cursoId         String  @map("curso_id") @db.Uuid
  areaId          String  @map("area_id") @db.Uuid
  peso            Decimal @db.Decimal(5, 2)
  puntajeObjetivo Decimal @map("puntaje_objetivo") @db.Decimal(5, 2)

  curso Curso @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  area  Area  @relation(fields: [areaId], references: [id], onDelete: Restrict)

  @@id([cursoId, areaId])
  @@map("cursos_areas_exigidas")
}

model CursoSkillExigida {
  cursoId    String  @map("curso_id") @db.Uuid
  skillId    String  @map("skill_id") @db.Uuid
  notaMinima Decimal @map("nota_minima") @db.Decimal(5, 2)

  curso Curso @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Restrict)

  @@id([cursoId, skillId])
  @@map("cursos_skills_exigidas")
}

model CursoModuloHabilitado {
  cursoId  String @map("curso_id") @db.Uuid
  moduloId String @map("modulo_id") @db.Uuid

  curso  Curso  @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  modulo Modulo @relation(fields: [moduloId], references: [id], onDelete: Restrict)

  @@id([cursoId, moduloId])
  @@index([moduloId], map: "idx_cmh_modulo")
  @@map("cursos_modulos_habilitados")
}

model LogCambioCurso {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cursoId        String         @map("curso_id") @db.Uuid
  fecha          DateTime       @default(now()) @db.Timestamptz(6)
  autorUsuarioId String         @map("autor_usuario_id") @db.Uuid
  accion         AccionLogCurso
  motivo         String
  previewImpacto Json?          @map("preview_impacto") @db.JsonB

  curso        Curso   @relation(fields: [cursoId], references: [id], onDelete: Restrict)
  autorUsuario Usuario @relation("LogCambioCurso_Autor", fields: [autorUsuarioId], references: [id], onDelete: Restrict)

  @@index([cursoId, fecha(sort: Desc)], map: "idx_log_cambios_curso")
  @@map("log_cambios_curso")
}

// =============================================================================
// COLABORADORES, USUARIOS, SESIONES, CONFIG
// =============================================================================

model Colaborador {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email            String         @unique @db.Citext
  nombre           String
  estadoEmpleado   EstadoEmpleado @default(ACTIVO) @map("estado_empleado")
  fechaOffBoarding DateTime?      @map("fecha_off_boarding") @db.Timestamptz(6)
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  usuario              Usuario?
  notasSkill           NotaSkill[]
  asignaciones         AsignacionCurso[]
  intentosBloque       IntentoBloque[]
  intentosTransversal  IntentoTransversal[]
  intentosEntrevistaIA IntentoEntrevistaIA[]

  @@map("colaboradores")
}

model Usuario {
  id                     String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  colaboradorId          String     @unique @map("colaborador_id") @db.Uuid
  rol                    RolUsuario @default(PARTICIPANTE)
  passwordHash           String     @map("password_hash")
  passwordInicialCaduca  DateTime?  @map("password_inicial_caduca") @db.Timestamptz(6)
  requiereCambioPassword Boolean    @default(true) @map("requiere_cambio_password")
  mfaHabilitado          Boolean    @default(false) @map("mfa_habilitado")
  mfaSecret              String?    @map("mfa_secret")
  requiereSetupMfa       Boolean    @default(false) @map("requiere_setup_mfa")
  intentosFallidos       Int        @default(0) @map("intentos_fallidos")
  bloqueado              Boolean    @default(false)
  ultimoLogin            DateTime?  @map("ultimo_login") @db.Timestamptz(6)
  createdAt              DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  colaborador              Colaborador                 @relation(fields: [colaboradorId], references: [id], onDelete: Restrict)
  historicoPasswords       HistoricoPassword[]
  notificaciones           Notificacion[]
  preferenciasNotificacion PreferenciaNotificacion[]
  aceptacionesAvisoPriv    AceptacionAvisoPrivacidad[]
  consultasLogs            ConsultaLog[]

  histRenombradosSkill  HistoricoRenombradoSkill[]  @relation("HistRenombradoSkill_Autor")
  histCambiosAreaSkill  HistoricoCambiosAreaSkill[] @relation("HistCambiosAreaSkill_Autor")
  histEstadosModulo     HistoricoEstadoModulo[]     @relation("HistEstadoModulo_Autor")
  logsCambioCurso       LogCambioCurso[]            @relation("LogCambioCurso_Autor")
  histEstadosAsignacion HistoricoEstadoAsignacion[] @relation("HistEstadoAsig_Autor")
  ajustesPlan           AjustePlan[]                @relation("AjustePlan_Autor")
  historicoNotasSkill   HistoricoNotaSkill[]        @relation("HistNotaSkill_Autor")
  activityLogs          ActivityLog[]
  mfaChallenges         MfaChallenge[]
  archivosSubidos       Archivo[]                     @relation("Archivo_SubidoPor")
  previewsEvalInicial   PreviewEvaluacionInicial[]    @relation("PreviewEvalInicial_CreadoPor")
  cargasEvalInicial     CargaEvaluacionInicial[]      @relation("CargaEvalInicial_AplicadoPor")
  idempotencyKeys       IdempotencyKey[]

  @@map("usuarios")
}

/// Challenges TOTP del segundo paso del login MFA. Una fila por intento de
/// login con MFA habilitado. Expira a los 5 min, se invalida tras 5 intentos
/// fallidos o tras un verify exitoso. Tabla append-only desde el codigo: el
/// `MfaService` solo crea, lee y marca `usado=true` / incrementa `intentos`.
model MfaChallenge {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuarioId String   @map("usuario_id") @db.Uuid
  creadoEn  DateTime @default(now()) @map("creado_en") @db.Timestamptz(6)
  expiraEn  DateTime @map("expira_en") @db.Timestamptz(6)
  usado     Boolean  @default(false)
  intentos  Int      @default(0)

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, creadoEn(sort: Desc)], map: "idx_mfa_challenges_usuario")
  @@map("mfa_challenges")
}

/// Audit log estructural (OWASP A09). Append-only desde el codigo:
/// `AuditLogService.record()` es fire-and-forget y NUNCA propaga errores
/// al request en curso. `usuarioId` es nullable porque eventos como
/// LOGIN_FAIL con email inexistente no tienen usuario asociado.
model ActivityLog {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuarioId   String?         @map("usuario_id") @db.Uuid
  accion      AccionAuditoria
  exito       Boolean
  recursoTipo String?         @map("recurso_tipo")
  recursoId   String?         @map("recurso_id")
  ip          String?
  userAgent   String?         @map("user_agent")
  requestId   String?         @map("request_id")
  metadata    Json?           @db.JsonB
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  usuario Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([usuarioId, createdAt(sort: Desc)], map: "idx_activity_logs_usuario")
  @@index([accion, createdAt(sort: Desc)], map: "idx_activity_logs_accion")
  @@map("activity_logs")
}

model HistoricoPassword {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuarioId   String   @map("usuario_id") @db.Uuid
  hash        String
  fechaCambio DateTime @default(now()) @map("fecha_cambio") @db.Timestamptz(6)

