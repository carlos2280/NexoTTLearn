  FILTRO

  @@map("filosofia_entrevista_enum")
}

enum ProfundidadEntrevista {
  JUNIOR
  SEMI_SENIOR
  SENIOR

  @@map("profundidad_entrevista_enum")
}

enum TonoEntrevista {
  CONVERSACIONAL
  FORMAL

  @@map("tono_entrevista_enum")
}

enum TipoEventoNotif {
  ASIGNACION_CURSO
  PLAN_RECALCULADO
  TRANSVERSAL_DISPONIBLE
  ENTREVISTA_IA_DISPONIBLE
  RECORDATORIO_DEADLINE
  CASO_REABIERTO
  RESULTADO_CIERRE
  CURSO_DEADLINE
  COLABORADOR_LISTO
  EXCEL_CARGADO
  MODULO_HUERFANO_SKILL
  PLANES_DESACTUALIZADOS
  CENTRO_REVISION

  @@map("tipo_evento_notif_enum")
}

enum CanalNotif {
