// =============================================================================
// NexoTT Learn — Prisma schema (PostgreSQL 16)
// -----------------------------------------------------------------------------
// Fuente de verdad: docs/NexoTTLearn/04_datos/modelo_fisico.md
// Convenciones:
//   - Modelos PascalCase (espanol). Campos camelCase. Mapeo a snake_case con
//     @map / @@map (D: Arquitectura "Tablas BD en snake_case espanol").
//   - PKs uuid con DEFAULT gen_random_uuid() (extension pgcrypto).
//   - Timestamps timestamptz almacenados en UTC.
//   - email en citext (extension citext) para case-insensitive.
//   - Notas y pesos numeric(5,2). null ≠ 0 (regla transversal D40).
//   - Enums Postgres nativos, valores SIN tildes/Ñ, espacios → "_".
//
// LO QUE PRISMA NO PUEDE EXPRESAR (anadir en migracion SQL inicial):
//   - CHECK constraints (rangos 0–100, suma de pesos = 100, coherencias rol↔estado, etc.)
//   - UNIQUE deferrable: (modulo_id, orden) en secciones; (seccion_id, orden) en bloques
//   - UNIQUE parcial: uq_intentos_bloque_mejor (con WHERE)
//   - Indices parciales WHERE: idx_skills_estado, idx_modulos_estado,
//     idx_bloques_skill_evaluable, idx_asignaciones_estado_asignado,
//     idx_intentos_bloque_skill_vigente, idx_notif_usuario_no_leidas, idx_notif_archivar.
//   - Trigger generico set_updated_at() BEFORE UPDATE.
//   - REVOKE UPDATE/DELETE en tablas append-only.
//   - Singleton CHECK (id = 1) en configuracion_sistema.
//   - Vistas / materialized views (mv_nota_skill_bloques, v_avance_plan, v_cobertura_skills_curso).
//
// Estos extras viven en prisma/migrations/<timestamp>_init/migration.sql como
// SQL adicional tras el DDL generado por `prisma migrate dev`.
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, citext]
}

// =============================================================================
// ENUMS
// =============================================================================

enum EstadoSkill {
  ACTIVA
  ARCHIVADA

  @@map("estado_skill_enum")
}

enum EstadoModulo {
  ACTIVO
  ARCHIVADO

  @@map("estado_modulo_enum")
}

enum TipoBloque {
  PARRAFO
  TIP
  VIDEO
  RECURSO
  CODIGO_ILUSTRATIVO
  QUIZ
  CODIGO_PREGUNTAS
  CODIGO_TESTS

  @@map("tipo_bloque_enum")
}

enum EstadoBloque {
  ACTIVO
  ELIMINADO

  @@map("estado_bloque_enum")
}

enum EstadoCurso {
  BORRADOR
  ACTIVO
  CERRADO
  ARCHIVADO

  @@map("estado_curso_enum")
}

enum DesbloqueoCurso {
  ENCADENADO
  SIEMPRE
  DESDE_FECHA

  @@map("desbloqueo_curso_enum")
}

enum EstadoEmpleado {
  ACTIVO
  EX_EMPLEADO

  @@map("estado_empleado_enum")
}

enum RolUsuario {
  ADMIN
  PARTICIPANTE

  @@map("rol_usuario_enum")
}

enum RolAsignacion {
  ASIGNADO
  VOLUNTARIO

  @@map("rol_asignacion_enum")
}

enum OrigenVoluntario {
  INICIATIVA
  REUTILIZACION

  @@map("origen_voluntario_enum")
}

enum EstadoAsignado {
  ASIGNADO
  EN_PROGRESO
  LISTO
  APTO
  NO_APTO
  RETIRADO

  @@map("estado_asignado_enum")
}

enum EstadoVoluntario {
  INSCRITO
  EN_PROGRESO
  LISTO
  COMPLETADO
  RETIRADO

  @@map("estado_voluntario_enum")
}

enum ResultadoEntrevistaCliente {
  PENDIENTE
  PASO
  NO_PASO

  @@map("resultado_entrevista_cliente_enum")
}

enum CaracterItemPlan {
  OBLIGATORIA
  OPCIONAL

  @@map("caracter_item_plan_enum")
}

enum RazonItemPlan {
  SKILL_FALTANTE
  SKILL_CERCA
  SKILL_YA_CUMPLE
  AJUSTE_ADMIN

  @@map("razon_item_plan_enum")
}

enum OrigenNotaSkill {
  ENTREVISTA_INICIAL
  BLOQUE
  TRANSVERSAL
  ENTREVISTA_IA

  @@map("origen_nota_skill_enum")
}

enum FilosofiaEntrevista {
